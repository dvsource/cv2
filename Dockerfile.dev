FROM python:3.13-slim

# Install Node 22 + Noto fonts
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl fonts-noto-core && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    mkdir -p /usr/share/fonts/noto && \
    cp /usr/share/fonts/truetype/noto/NotoSans-*.ttf /usr/share/fonts/noto/ && \
    cp /usr/share/fonts/truetype/noto/NotoSansMono-*.ttf /usr/share/fonts/noto/ && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Python deps
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Node deps (cached layer — only reinstalls if package files change)
COPY web/package.json web/package-lock.json ./web/
RUN cd web && npm ci

# App source (overridden at runtime via watch sync)
COPY server.py build_cv.py db.py llm.py ./
COPY web/ ./web/

EXPOSE 5000 5173

# Flask debug=True gives Werkzeug auto-reload on .py changes.
# Vite dev server gives HMR on web/src changes.
# Both are triggered by Docker watch syncing files into the container.
CMD ["/bin/sh", "-c", "cd /app/web && npm run dev -- --host 0.0.0.0 & cd /app && python server.py"]
